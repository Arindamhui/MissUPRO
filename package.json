{
  "name": "missupro",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo dev --concurrency=20",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "postinstall": "patch-package",
    "db:generate": "cd packages/db && npx drizzle-kit generate",
    "db:migrate": "cd packages/db && npx drizzle-kit migrate",
    "db:studio": "cd packages/db && npx drizzle-kit studio",
    "db:seed": "cd packages/db && npx tsx seed/index.ts",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "copy-anything": "3.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "packageManager": "npm@10.0.0"
}
