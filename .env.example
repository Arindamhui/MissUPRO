# MissUPRO Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to source control.

# ── Neon PostgreSQL ──
DATABASE_URL=postgresql://missupro:<password>@<project-id>.neon.tech/missupro_dev?sslmode=require

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Razorpay ──
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ── Agora RTC ──
AGORA_APP_ID=...
AGORA_APP_CERTIFICATE=...

# ── Cloudflare R2 ──
CLOUDFLARE_R2_ACCESS_KEY=...
CLOUDFLARE_R2_SECRET_KEY=...
CLOUDFLARE_R2_BUCKET=missupro-assets
CLOUDFLARE_R2_ENDPOINT=https://...r2.cloudflarestorage.com

# ── Sentry ──
SENTRY_DSN=https://...@sentry.io/...

# ── Clerk ──
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── App URLs ──
ADMIN_EMAIL=admin@missupro.com
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
WS_URL=ws://localhost:4001

# ── JWT (internal admin sessions) ──
JWT_SECRET=change-me-to-a-random-256-bit-key
JWT_REFRESH_SECRET=change-me-different-random-key
